# Shared Salesforce connected app credentials
SF_CONSUMER_KEY=
SF_CONSUMER_SECRET=
SF_REDIRECT_HOST=http://localhost
SF_REDIRECT_PORTS=8080,18080,28080

# Salesforce hosts
SF_ENV_PROD_HOST=login.salesforce.com
SF_ENV_MCUAT8451_HOST=kpm-8451--mcuat8451.sandbox.my.salesforce.com

# Optional per-env connected app overrides
# SF_ENV_PROD_CLIENT_ID=
# SF_ENV_PROD_CLIENT_SECRET=
# SF_ENV_MCUAT8451_CLIENT_ID=
# SF_ENV_MCUAT8451_CLIENT_SECRET=

# TLS / corporate CA settings
SF_VERIFY_TLS=true
# SF_CA_BUNDLE=/path/to/corporate-ca.pem

